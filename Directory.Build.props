<Project>
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>

    <Version>0.1.0.2</Version>
    <AssemblyVersion>0.1.0.2</AssemblyVersion>
    <FileVersion>0.1.0.2</FileVersion>
    <InformationalVersion>0.1.0.2</InformationalVersion>
    <AIKernelPackageVersion>0.1.0.2</AIKernelPackageVersion>

    <Authors>Takuya Sogawa</Authors>
    <Company>AIKernel-NET</Company>
    <PackageLicenseExpression>Apache-2.0</PackageLicenseExpression>
    <PackageProjectUrl>https://www.nuget.org/profiles/AIKernel-NET</PackageProjectUrl>
    <RepositoryUrl>https://github.com/AIKernel-NET/AIKernel.Core</RepositoryUrl>
    <Copyright>Copyright © 2026 Takuya Sogawa of AIKernel-NET</Copyright>
    <PackageTags>aikernel;aikernel-core;ai-os;kernel;provider;hosting;rom;vfs;context;execution;immutability;fail-closed;capability-modules;dynamicslm;seedslm;hatl;admissibility;semantic-compilation</PackageTags>
    <PackageReleaseNotes>
      AIKernel.Core package family v0.1.0 - First executable runtime baseline aligned with AIKernel.NET contract packages v0.1.0. Core provides Result/Option/Either, ResultStep/ReplayLog semantics, DSL and ROM runtime adapters, Kernel orchestration, Provider integration, and MemoryRegion/MemoryMapper runtime adapters over the contract-owned AIKernel.Abstractions.Memory surface. GPU and Native ABI implementations remain external Capability packages.
    </PackageReleaseNotes>
    <RestoreAdditionalProjectSources>$(MSBuildThisFileDirectory)..\artifacts\packages;$(RestoreAdditionalProjectSources)</RestoreAdditionalProjectSources>
  </PropertyGroup>

  <ItemGroup>
    <AssemblyMetadata Include="AIKernel.ImmutabilityPrinciple" Value="Collections must use System.Collections.Immutable." />
    <AssemblyMetadata Include="AIKernel.FailClosedPrinciple" Value="Exception handling must ensure no partial success." />
  </ItemGroup>
</Project>
